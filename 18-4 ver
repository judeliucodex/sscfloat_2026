// --- MOTOR CHUNKS & SEQUENCES ---

void stepMotorChunk(int steps, SystemMode expectedMode) {
  for (int i = 0; i < steps; i++) {
    if (currentMode != expectedMode) return; 
    
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(motorSpeed);
    digitalWrite(stepPin, LOW);
    delayMicroseconds(motorSpeed);
    
    if (i % 20 == 0) taskYIELD(); 
  }
}

void runStepperSequence() {
  motorSpeed = 600; 
  addLog("Sequence: Sinking...");
  
  digitalWrite(dirPin, LOW);
  while(digitalRead(BUTTON_PIN_1) == HIGH && currentMode == MODE_SEQUENCE) {  
      stepMotorChunk(20, MODE_SEQUENCE);
  }
  if (currentMode != MODE_SEQUENCE) return; 
  addLog("Sequence: Bottom Reached.");
  
  uint32_t waitTime = 45000; 
  if (xSemaphoreTake(configLock, portMAX_DELAY)) { waitTime = floatWaitTimeMs; xSemaphoreGive(configLock); }
  
  addLog("Sequence: Waiting " + String(waitTime/1000) + "s");
  uint32_t startTime = millis();
  while ((millis() - startTime) < waitTime) {
    if (currentMode != MODE_SEQUENCE) return; 
    vTaskDelay(pdMS_TO_TICKS(100)); 
  }
  if (currentMode != MODE_SEQUENCE) return; 
  
  addLog("Sequence: Floating...");
  digitalWrite(dirPin, HIGH);
  while(digitalRead(BUTTON_PIN_2) == HIGH && currentMode == MODE_SEQUENCE) {  
      stepMotorChunk(20, MODE_SEQUENCE);
  }
  
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    if (currentMode == MODE_SEQUENCE) {
      currentMode = MODE_HOLD_DEPTH;
      addLog("Sequence: Complete. Transition to HOLD.");
    }
    xSemaphoreGive(modeLock);
  }
}

void runBangBangController() {
  motorSpeed = 2000; 
  
  float depthCopy = 0.0;
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) { depthCopy = currentRelativeDepth; xSemaphoreGive(dataLock); }

  float targetMeters = 0.40;
  if (xSemaphoreTake(configLock, portMAX_DELAY)) { targetMeters = targetDepthCm / 100.0; xSemaphoreGive(configLock); }

  float upperBound = targetMeters + 0.02;
  float lowerBound = targetMeters - 0.02;

  // depthCopy is positive going down
  if (depthCopy > upperBound && digitalRead(BUTTON_PIN_2) == HIGH) {
    digitalWrite(dirPin, HIGH); // Float up
    stepMotorChunk(50, MODE_HOLD_DEPTH);
  } 
  else if (depthCopy < lowerBound && digitalRead(BUTTON_PIN_1) == HIGH) {
    digitalWrite(dirPin, LOW); // Sink down
    stepMotorChunk(50, MODE_HOLD_DEPTH);
  } 
  else {
    vTaskDelay(pdMS_TO_TICKS(50));
  }
}

// --- MOTOR TASK ---
void motorTask(void *parameter) {
  while(1) {
    SystemMode currentModeCopy;
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      currentModeCopy = currentMode;
      xSemaphoreGive(modeLock);
    }
    
    if (currentModeCopy == MODE_SEQUENCE) {
      runStepperSequence();
    } 
    else if (currentModeCopy == MODE_HOLD_DEPTH) {
      runBangBangController();
    } 
    else if (currentModeCopy == MODE_MANUAL) {
      motorSpeed = 1000; 
      if (manualDirection == 1) { // Float UP
        digitalWrite(dirPin, HIGH);
        if (digitalRead(BUTTON_PIN_2) == HIGH) stepMotorChunk(10, MODE_MANUAL);
      } else if (manualDirection == -1) { // Sink DOWN
        digitalWrite(dirPin, LOW);
        if (digitalRead(BUTTON_PIN_1) == HIGH) stepMotorChunk(10, MODE_MANUAL);
      }
      vTaskDelay(pdMS_TO_TICKS(10));
    }
    else if (currentModeCopy == MODE_TEST) {
      motorSpeed = 2500; 
      digitalWrite(dirPin, HIGH); 
      for (int i = 0; i < 2000; i++) { 
        if (currentMode != MODE_TEST || digitalRead(BUTTON_PIN_2) == LOW) break;
        digitalWrite(stepPin, HIGH); delayMicroseconds(motorSpeed);
        digitalWrite(stepPin, LOW); delayMicroseconds(motorSpeed);
      }
      if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
        if(currentMode == MODE_TEST) currentMode = MODE_IDLE;
        xSemaphoreGive(modeLock);
      }
      addLog("Test Spin Ended");
    }
    else {
      vTaskDelay(pdMS_TO_TICKS(100)); 
    }
  }
}

// --- SETUP & LOOP ---
void setup() {
  Serial.begin(115200); 
  delay(1000);
  
  dataLock = xSemaphoreCreateMutex();
  modeLock = xSemaphoreCreateMutex();
  configLock = xSemaphoreCreateMutex();
  logLock = xSemaphoreCreateMutex();

  Wire.begin(CUSTOM_SDA_PIN, CUSTOM_SCL_PIN);
  
  if (!sensor.init()) {
    Serial.println("Sensor failed to initialize.");
    addLog("CRITICAL: Sensor Init Failed");
  } else {
    sensor.setFluidDensity(997); 
    sensor.read();
    lastValidDepth = sensor.depth();
    surfaceDepthOffset = lastValidDepth; 
    hasFirstReading = true;
    addLog("System Boot OK");
  }
  
  pinMode(dirPin, OUTPUT);
  pinMode(stepPin, OUTPUT);
  pinMode(BUTTON_PIN_1, INPUT_PULLUP);
  pinMode(BUTTON_PIN_2, INPUT_PULLUP); 
  
  WiFi.mode(WIFI_AP);
  WiFi.softAP(ssid, password);
  WiFi.setSleep(false);
  
  ArduinoOTA.begin();
  
  server.on("/data", handleData);
  server.on("/status", handleStatus);
  server.on("/debug", handleDebug);
  server.on("/move", handleMove);
  server.on("/", []() { server.sendHeader("Location", "/debug"); server.send(303); });
  
  server.begin();
  
  xTaskCreatePinnedToCore(sensorTask, "SensorTask", 4096, NULL, 2, &sensorTaskHandle, 0);
  xTaskCreatePinnedToCore(webTask, "WebTask", 4096, NULL, 1, &webTaskHandle, 0);
  xTaskCreatePinnedToCore(motorTask, "MotorTask", 4096, NULL, 3, &motorTaskHandle, 1);
}

void loop() {
  ArduinoOTA.handle(); 
  
  static int lastStationNum = -1;
  int currentStations = WiFi.softAPgetStationNum();
  if (currentStations != lastStationNum) {
    Serial.printf("Connected clients to SSCFloat: %d\n", currentStations);
    lastStationNum = currentStations;
  }
  
  vTaskDelay(pdMS_TO_TICKS(1000));
}
