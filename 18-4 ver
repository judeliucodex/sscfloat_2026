const char* password = "DT1234dt";
WebServer server(80);

// --- SENSOR VARIABLES & BUFFERS ---
float currentRelativeDepth = 0.0; // Positive going down (internal logic)
float surfaceDepthOffset = 0.0;   
bool sensorConnected = false;

// Spike Filter
float lastValidDepth = 0.0;
bool hasFirstReading = false;

// Fast Buffer: 100ms readings for 5 seconds (50 elements) - Displayed in /debug
float fastDepthBuf[50] = {0};
float fastPressureBuf[50] = {0};
int fastIdx = 0;

// Slow Buffer: 1 second readings for 120 seconds (120 elements) - Displayed in /data
float slowPressureBuf[120] = {0};
int slowIdx = 0;
int slowTickCounter = 0;

int iterationCount = 0;

// --- MOTOR PINS & SETTINGS ---
const int dirPin  = 4;
const int stepPin = 16;
int motorSpeed = 2000;

// --- LIMIT SWITCHES ---
#define BUTTON_PIN_1 19    // Upper Limit (Sinking stop)
#define BUTTON_PIN_2 18    // Lower Limit (Floating stop)

// --- STATE MACHINE ---
enum SystemMode {
  MODE_IDLE,
  MODE_SEQUENCE,
  MODE_HOLD_DEPTH,
  MODE_MANUAL,
  MODE_TEST
};
volatile SystemMode currentMode = MODE_IDLE; 
volatile int manualDirection = 0; // 1 for UP, -1 for DOWN

// --- CONFIGURATION VARIABLES ---
uint32_t floatWaitTimeMs = 45000;      // Default: 45 seconds at the bottom
uint32_t sensorReadIntervalMs = 100;   // Default: 100ms (10Hz) sensor reading
float targetDepthCm = 40.0;            // Default: 40 cm target holding depth

// --- LOGGING BUFFER ---
String systemLogs[20];
int logIdx = 0;

// --- MUTEXES & TASK HANDLES ---
SemaphoreHandle_t dataLock = NULL;
SemaphoreHandle_t modeLock = NULL;
SemaphoreHandle_t configLock = NULL;
SemaphoreHandle_t logLock = NULL;

TaskHandle_t sensorTaskHandle = NULL;
TaskHandle_t webTaskHandle = NULL;
TaskHandle_t motorTaskHandle = NULL;

// --- HELPER: LOGGING ---
void addLog(String msg) {
  if (xSemaphoreTake(logLock, portMAX_DELAY)) {
    unsigned long t = millis() / 1000;
    systemLogs[logIdx] = "[" + String(t) + "s] " + msg;
    logIdx = (logIdx + 1) % 20;
    xSemaphoreGive(logLock);
  }
  Serial.println(msg);
}

// --- SENSOR TASK ---
void sensorTask(void *parameter) {
  while(1) {
    bool success = sensor.read();
    
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
      sensorConnected = success;
      if (success) {
        float mbar = sensor.pressure();
        float rawDepth = sensor.depth();

        // 1. SPIKE FILTER: Reject depth jumps > 3m
        if (!hasFirstReading || abs(rawDepth - lastValidDepth) <= 3.0) {
          lastValidDepth = rawDepth;
          // Calculate internal depth (positive values as we descend)
          currentRelativeDepth = lastValidDepth - surfaceDepthOffset; 
          hasFirstReading = true;
        } else {
          addLog("Spike Filtered: " + String(rawDepth) + "m");
        }

        // 2. FAST BUFFER (100ms) - Stores negative depth to represent descent (-5m = down 5m)
        fastPressureBuf[fastIdx] = mbar;
        fastDepthBuf[fastIdx] = -currentRelativeDepth; 
        fastIdx = (fastIdx + 1) % 50;

        // 3. SLOW BUFFER (1 second / every 10th reading)
        slowTickCounter++;
        if (slowTickCounter >= 10) {
          slowPressureBuf[slowIdx] = mbar;
          slowIdx = (slowIdx + 1) % 120;
          slowTickCounter = 0;
        }
        
        iterationCount++;
      }
      xSemaphoreGive(dataLock);
    }
    
    uint32_t delayMs = 100; 
    if (xSemaphoreTake(configLock, portMAX_DELAY)) {
      delayMs = sensorReadIntervalMs;
      xSemaphoreGive(configLock);
    }
    vTaskDelay(pdMS_TO_TICKS(delayMs)); 
  }
}

// --- WEB SERVER TASK ---
void webTask(void *parameter) {
  while(1) {
    server.handleClient();
    vTaskDelay(pdMS_TO_TICKS(10));
  }
}

// --- WEB ENDPOINTS ---

// 1. DATA Endpoint (Slow 1s Buffer - Mbar Only)
void handleData() {
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
    String data = "Historical Mbar Readings (1 sec intervals, past 120s):\n\n";
    for (int i = 0; i < 120; i++) {
      int idx = (slowIdx - 1 - i + 120) % 120;
      if (slowPressureBuf[idx] > 0.0) { // Only show populated data
        data += String(slowPressureBuf[idx]) + " mbar\n";
      }
    }
    xSemaphoreGive(dataLock);
    server.send(200, "text/plain", data);
  } else {
    server.send(500, "text/plain", "Mutex Lock Timeout");
  }
}

// 2. JSON Status for AJAX updates (Fast 100ms Buffer - Mbar & Depth)
void handleStatus() {
  DynamicJsonDocument doc(4096); // Expanded document for Arrays
  
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
    doc["sensorOk"] = sensorConnected;
    
    // Package 50 element arrays for graphing
    JsonArray fDepth = doc.createNestedArray("fastDepth");
    JsonArray fPress = doc.createNestedArray("fastPress");
    for(int i = 0; i < 50; i++) {
       int idx = (fastIdx + i) % 50;
       fDepth.add(fastDepthBuf[idx]);
       fPress.add(fastPressureBuf[idx]);
    }
    xSemaphoreGive(dataLock);
  }

  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    doc["mode"] = currentMode;
    xSemaphoreGive(modeLock);
  }

  doc["limitU"] = digitalRead(BUTTON_PIN_1) == LOW; 
  doc["limitL"] = digitalRead(BUTTON_PIN_2) == LOW; 

  if (xSemaphoreTake(logLock, portMAX_DELAY)) {
    JsonArray logs = doc.createNestedArray("logs");
    for(int i = 0; i < 20; i++) {
      int idx = (logIdx + i) % 20;
      if (systemLogs[idx].length() > 0) {
        logs.add(systemLogs[idx]);
      }
    }
    xSemaphoreGive(logLock);
  }

  String output;
  serializeJson(doc, output);
  server.send(200, "application/json", output);
}

// Momentary Movement Handler
void handleMove() {
  if (server.hasArg("dir")) {
    int dir = server.arg("dir").toInt();
    if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
      if (dir == 1 || dir == -1) {
        currentMode = MODE_MANUAL;
        manualDirection = dir;
      } else {
        if (currentMode == MODE_MANUAL) currentMode = MODE_IDLE;
        manualDirection = 0;
      }
      xSemaphoreGive(modeLock);
    }
  }
  server.send(200, "text/plain", "OK");
}

