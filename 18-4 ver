    if (action == "tare") {
      if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
        surfaceDepthOffset = lastValidDepth; // Zero to current filtered depth
        xSemaphoreGive(dataLock);
      }
      addLog("Sensor Tared to 0m");
    } 
