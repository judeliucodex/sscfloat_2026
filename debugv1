#include <Wire.h>
#include <MS5837.h>
#include <WiFi.h>
#include <WebServer.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "freertos/semphr.h"
#include <ArduinoOTA.h>
#include <Update.h>

// --- I2C PINS ---
#define CUSTOM_SDA_PIN 21
#define CUSTOM_SCL_PIN 22

MS5837 sensor;

// --- WIFI CREDENTIALS ---
const char* ssid     = "SSCFloat";
const char* password = "DT1234dt";
WebServer server(80);

// --- SENSOR VARIABLES ---
float depthHistory[120]; 
int sensorIdx = 0;
int iterationCount = 0;
float currentRelativeDepth = 0.0; 
float surfaceDepthOffset = 0.0;   

// --- MOTOR PINS & SETTINGS ---
const int dirPin  = 4;
const int stepPin = 16;

// --- LIMIT SWITCHES ---
#define BUTTON_PIN_1 19    // Upper Limit (Sinking stop) - Active LOW
#define BUTTON_PIN_2 18    // Lower Limit (Floating stop) - Active LOW

// --- STATE MACHINE ---
enum SystemMode {
  MODE_IDLE,
  MODE_SEQUENCE,
  MODE_HOLD_DEPTH
};
volatile SystemMode currentMode = MODE_IDLE; 

// --- CONFIGURATION VARIABLES ---
uint32_t floatWaitTimeMs = 45000;      // Default: 45 seconds at the bottom
uint32_t sensorReadIntervalMs = 100;   // Default: 100ms (10Hz) sensor reading
float targetDepthCm = 40.0;            // Default: 40 cm target holding depth
int targetMotorSpeed = 1000;           // Constant Step delay in us

// --- MUTEXES & TASK HANDLES ---
SemaphoreHandle_t dataLock = NULL;
SemaphoreHandle_t modeLock = NULL;
SemaphoreHandle_t configLock = NULL;

TaskHandle_t sensorTaskHandle = NULL;
TaskHandle_t webTaskHandle = NULL;
TaskHandle_t motorTaskHandle = NULL;

// --- SENSOR TASK ---
void sensorTask(void *parameter) {
  while(1) {
    sensor.read();
    
    if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
      currentRelativeDepth = sensor.depth() - surfaceDepthOffset; 
      depthHistory[sensorIdx] = currentRelativeDepth * 100.0; 
      sensorIdx = (sensorIdx + 1) % 120;
      iterationCount++;
      xSemaphoreGive(dataLock);
    }
    
    uint32_t delayMs = 100; 
    if (xSemaphoreTake(configLock, portMAX_DELAY)) {
      delayMs = sensorReadIntervalMs;
      xSemaphoreGive(configLock);
    }
    
    vTaskDelay(pdMS_TO_TICKS(delayMs)); 
  }
}

// --- WEB SERVER TASK ---
void webTask(void *parameter) {
  while(1) {
    server.handleClient();
    vTaskDelay(pdMS_TO_TICKS(10));
  }
}

// --- WEB ENDPOINTS ---

// 1. /data Endpoint (Now highly verbose for debugging)
void handleData() {
  String json = "{";
  
  // System Metrics
  json += "\"uptime\":" + String(millis()) + ",";
  json += "\"freeHeap\":" + String(ESP.getFreeHeap()) + ",";
  json += "\"wifiClients\":" + String(WiFi.softAPgetStationNum()) + ",";

  // Hardware Status
  json += "\"limitUpper\":" + String(digitalRead(BUTTON_PIN_1) == LOW ? 1 : 0) + ",";
  json += "\"limitLower\":" + String(digitalRead(BUTTON_PIN_2) == LOW ? 1 : 0) + ",";

  // Current Mode
  SystemMode modeCopy;
  if (xSemaphoreTake(modeLock, portMAX_DELAY)) {
    modeCopy = currentMode;
    xSemaphoreGive(modeLock);
  }
  json += "\"mode\":" + String(modeCopy) + ",";
  
  // Configuration Settings
  uint32_t currWait = 0, currInterval = 0; float currDepth = 40.0; int currSpeed = 1000;
  if (xSemaphoreTake(configLock, portMAX_DELAY)) {
    currWait = floatWaitTimeMs;
    currInterval = sensorReadIntervalMs;
    currDepth = targetDepthCm;
    currSpeed = targetMotorSpeed;
    xSemaphoreGive(configLock);
  }
  json += "\"cfgWait\":" + String(currWait) + ",";
  json += "\"cfgInterval\":" + String(currInterval) + ",";
  json += "\"cfgTargetDepth\":" + String(currDepth) + ",";
  json += "\"cfgMotorSpeed\":" + String(currSpeed) + ",";

  // Data & History
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
    json += "\"currentDepth\":" + String(currentRelativeDepth * 100.0) + ",";
    json += "\"sensorIdx\":" + String(sensorIdx) + ",";
    json += "\"iterationCount\":" + String(iterationCount) + ",";
    json += "\"history\":[";
    
    bool first = true;
    int maxItems = iterationCount < 120 ? iterationCount : 120;
    for (int i = 0; i < maxItems; i++) {
      int idx = (sensorIdx - maxItems + i + 120) % 120; 
      if (!first) json += ",";
      json += String(depthHistory[idx]);
      first = false;
    }
    json += "]";
    xSemaphoreGive(dataLock);
  }
  json += "}";
  server.send(200, "application/json", json);
}

