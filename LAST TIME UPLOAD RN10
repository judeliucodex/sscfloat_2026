#include <Wire.h>
#include <MS5837.h>
#include <WiFi.h>
#include <WebServer.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "freertos/semphr.h"
#include <ArduinoOTA.h>
#include <Update.h>

// --- I2C PINS ---
#define CUSTOM_SDA_PIN 21
#define CUSTOM_SCL_PIN 22

MS5837 sensor;
bool sensorActive = false; // Flag to track hardware status

// --- WIFI CREDENTIALS ---
const char* ssid     = "SSCFloat RN10";
const char* password = "DT1234dt";
WebServer server(80);

// --- SENSOR VARIABLES ---
#define MAX_PACKETS 240
char dataPackets[MAX_PACKETS][32]; 
int sensorIdx = 0;
int iterationCount = 0;
float currentRelativeDepth = 0.0; 
float surfaceDepthOffset = 0.0;   

// --- MOTOR PINS & SETTINGS ---
const int dirPin  = 4;
const int stepPin = 16;
int motorSpeed = 2000;

// --- LIMIT SWITCHES ---
#define BUTTON_PIN_1 19    
#define BUTTON_PIN_2 18    

// --- STATE MACHINE ---
enum SystemMode {
  MODE_IDLE,
  MODE_SEQUENCE
};
volatile SystemMode currentMode = MODE_IDLE; 

// --- CONFIGURATION VARIABLES ---
uint32_t floatWaitTimeMs = 45000;      
uint32_t sensorReadIntervalMs = 1000;  

// --- MUTEXES & TASK HANDLES ---
SemaphoreHandle_t dataLock = NULL;
SemaphoreHandle_t modeLock = NULL;
SemaphoreHandle_t configLock = NULL;

TaskHandle_t sensorTaskHandle = NULL;
TaskHandle_t webTaskHandle = NULL;
TaskHandle_t motorTaskHandle = NULL;

// --- SENSOR TASK ---
void sensorTask(void *parameter) {
  while(1) {
    if (sensorActive) {
      sensor.read();
      
      if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
        // INVERTED: Downward movement now results in a negative value
        currentRelativeDepth = -(sensor.depth() - surfaceDepthOffset); 
        unsigned long floatTimeSec = millis() / 1000; 
        float pressureKpa = sensor.pressure() / 10.0; 

        snprintf(dataPackets[sensorIdx], 32, "RN10 %lus %.1fkpa %.2fm", 
                 floatTimeSec, pressureKpa, currentRelativeDepth);

        sensorIdx = (sensorIdx + 1) % MAX_PACKETS;
        iterationCount++;
        xSemaphoreGive(dataLock);
      }
    } else {
      // Log error if sensor is missing
      if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
        unsigned long floatTimeSec = millis() / 1000;
        snprintf(dataPackets[sensorIdx], 32, "RN10 %lus SENSOR_ERROR", floatTimeSec);
        sensorIdx = (sensorIdx + 1) % MAX_PACKETS;
        iterationCount++;
        xSemaphoreGive(dataLock);
      }
    }
    
    uint32_t delayMs = 1000; 
    if (xSemaphoreTake(configLock, portMAX_DELAY)) {
      delayMs = sensorReadIntervalMs;
      xSemaphoreGive(configLock);
    }
    vTaskDelay(pdMS_TO_TICKS(delayMs)); 
  }
}

// --- WEB SERVER TASK ---
void webTask(void *parameter) {
  while(1) {
    server.handleClient();
    vTaskDelay(pdMS_TO_TICKS(10));
  }
}

// --- WEB ENDPOINTS ---

void handleData() {
  if (xSemaphoreTake(dataLock, portMAX_DELAY)) {
    // 1. Check what the client last saw
    int clientLastIter = -1;
    if (server.hasArg("last")) {
      clientLastIter = server.arg("last").toInt();
    }

    // 2. Start building the response with the CURRENT iteration count
    String data = "ITER:" + String(iterationCount) + "\n";
    data += sensorActive ? "Current Depth: " + String(currentRelativeDepth * 100.0) + " cm\n" : "SENSOR DISCONNECTED\n";

    // 3. Figure out how many packets are actually new
    int totalAvailable = iterationCount < MAX_PACKETS ? iterationCount : MAX_PACKETS;
    int newPackets = iterationCount - clientLastIter;

    // If client is brand new (-1), or fell too far behind our buffer limit, send all available
    if (clientLastIter == -1 || newPackets > totalAvailable) {
      newPackets = totalAvailable;
    } else if (newPackets < 0) {
      newPackets = 0; // Failsafe in case ESP32 restarted but browser didn't
    }

    data.reserve(newPackets * 32 + 100);

    // 4. Append only the NEW packets
    for (int i = 0; i < newPackets; i++) {
      int idx = (sensorIdx - 1 - i + MAX_PACKETS) % MAX_PACKETS;
      data += String(dataPackets[idx]) + "\n";
    }

    xSemaphoreGive(dataLock);
    server.send(200, "text/plain", data);
  }
}

