              logBox.innerHTML += lines[i] + "<br>";
              newDataAdded = true;
            }
          }

          if (newDataAdded) {
            logBox.scrollTop = logBox.scrollHeight;
          }

        } catch (error) {
          console.log("Connection to ESP32 lost...");
          document.getElementById('depthDisplay').innerText = "CONNECTION LOST - Retrying...";
